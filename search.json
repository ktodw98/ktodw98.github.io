---
layout: null
---
[
{% assign visible_posts = site.posts | where_exp: "item", "item.draft != true" %}
{% assign visible_notes = site.notes | where_exp: "item", "item.draft != true" %}
{% assign visible_docs = visible_posts | concat: visible_notes %}
{% for doc in visible_docs %}
  {
    "title": {{ doc.title | jsonify }},
    "url": {{ doc.url | relative_url | jsonify }},
    "date": {{ doc.date | date: "%Y-%m-%d" | jsonify }},
    "description": {{ doc.description | default: doc.excerpt | strip_html | strip_newlines | jsonify }},
    "tags": {{ doc.tags | jsonify }},
    "type": {{ doc.collection | replace: "posts", "post" | replace: "notes", "note" | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
